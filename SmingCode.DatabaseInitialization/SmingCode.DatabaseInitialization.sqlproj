<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build">
  <Sdk Name="Microsoft.Build.Sql" Version="2.2.0" />
  <PropertyGroup>
    <Name>SmingCode.DatabaseInitialization</Name>
    <ProjectGuid>{752AAE44-CD4A-4857-B19D-2DA9D417D7DA}</ProjectGuid>
    <DSP>Microsoft.Data.Tools.Schema.Sql.SqlAzureV12DatabaseSchemaProvider</DSP>
    <ModelCollation>1033, CI</ModelCollation>
  </PropertyGroup>
  <ItemGroup>
    <SqlCmdVariable Include="CaName">
      <Value>$(SqlCmdVar__2)</Value>
      <DefaultValue>empty</DefaultValue>
    </SqlCmdVariable>
  </ItemGroup>
  <Target Name="BeforeBuild">
    <Delete Files="$(BaseIntermediateOutputPath)\project.assets.json" />
  </Target>
  <ItemGroup>
    <PostDeploy Include="initialize-user.sql" />
  </ItemGroup>
</Project>